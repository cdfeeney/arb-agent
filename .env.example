# --- Kalshi (read + trade) ---
KALSHI_API_KEY_ID=your_kalshi_api_key_id
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private_key.pem

# --- Polymarket (trade only — read uses the public Gamma/CLOB endpoints) ---
# EOA or proxy-wallet private key on Polygon. Required to sign CLOB orders.
# DO NOT commit. Without it, the bot can still read Polymarket but won't
# place orders even with execution.allow_send=true.
POLYMARKET_PRIVATE_KEY=0x...
# Optional: address that holds USDC. Most retail proxy wallets have funder
# == proxy address; leave blank to let py-clob-client default.
POLYMARKET_FUNDER=

# --- Twilio SMS alerts (optional) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
SMS_TO=+12125551234
SMS_FROM=+18885551234

# --- Anthropic (LLM market verifier — eliminates false fuzzy matches) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
